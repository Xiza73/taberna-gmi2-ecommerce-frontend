# Copia este archivo a `.env` y completa los valores. NO commitees `.env`.

# Backend API base URL (ver `../backend/.env` o levantar local con `docker-compose up`).
VITE_API_BASE_URL=http://localhost:3000/api

# Google OAuth client ID (web). Sacalo de https://console.cloud.google.com/apis/credentials
# Necesario para el botón "Continuar con Google" en login/register.
# VITE_GOOGLE_CLIENT_ID=

# MercadoPago public key (sandbox o producción).
# https://www.mercadopago.com.pe/developers/panel/app
# Solo necesario si usamos checkout embedded; para Checkout Pro redirect basta con
# que el back tenga el access token. Mantenido por si llega a hacer falta.
# VITE_MP_PUBLIC_KEY=
