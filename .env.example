# Copia este archivo a `.env` y completa los valores. NO commitees `.env`.

# Backend API base URL (ver `../backend/.env` o levantar local con `docker-compose up`).
VITE_API_BASE_URL=http://localhost:3000/api

# Google OAuth client ID (web). DEBE coincidir con el GOOGLE_CLIENT_ID del back
# para que el back pueda verificar el idToken. El client_id ES público, va en el
# código del navegador; el client_secret nunca entra al frontend.
#
# Obtenelo de https://console.cloud.google.com/apis/credentials → tu cliente
# OAuth Web. Asegurate que `http://localhost:5173` (dev) y tu dominio de
# producción estén en "Authorized JavaScript origins".
VITE_GOOGLE_CLIENT_ID=

# MercadoPago public key (sandbox o producción). Solo necesario si usamos
# checkout embedded; para Checkout Pro redirect basta con que el back tenga
# el access token. Mantenido por si llega a hacer falta.
# https://www.mercadopago.com.pe/developers/panel/app
# VITE_MP_PUBLIC_KEY=

# =====================================================
# Datos del negocio para pagos manuales (Yape/Plin/Transferencia)
# y opciones de pickup. Eventualmente esto debería vivir en un
# módulo `store-config` del back; por ahora va via env del front
# (todos PÚBLICOS — el cliente los ve en pantalla).
# =====================================================

# Número Yape/Plin del negocio (ej "999 999 999")
VITE_YAPE_NUMBER="999 999 999"

# Cuenta bancaria para transferencias
VITE_BANK_NAME="Banco de Crédito del Perú (BCP)"
VITE_BANK_ACCOUNT="194-1234567-8-90"
VITE_BANK_CCI="002-194-001234567890-12"
VITE_BANK_HOLDER="Lumière S.A.C."

# Número de WhatsApp donde el customer manda comprobantes (formato internacional sin +)
# Ej: "51999999999" para Perú
VITE_WHATSAPP_NUMBER="51999999999"

# Texto libre con dirección de la tienda + horarios (multi-line con \n permitido)
VITE_PICKUP_ADDRESS="Av. Larco 123, Miraflores, Lima\nLun-Sáb 10:00 a 20:00"
